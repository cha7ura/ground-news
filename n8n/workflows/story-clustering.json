    {
      "parameters": {
        "jsCode": "// Prepare story data for insertion\nconst cluster = $input.item.json;\n\nreturn {\n  json: {\n    title: cluster.seed_article.title,\n    article_count: cluster.article_count,\n    source_count: cluster.source_count,\n    first_seen_at: cluster.seed_article.published_at || new Date().toISOString()\n  }\n};"
      },
      "id": "prepare-story",
      "name": "Prepare Story Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, -100]
    },
    {
      "parameters": {
        "jsCode": "// Link articles to the newly created story\nconst cluster = $('Has Clusters?').item.json;\nconst story = $('Create Story').item.json;\n\nif (!story || !story.id) {\n  return [];\n}\n\n// Create story_articles junction records and update articles\nconst updates = cluster.articles.map((article, index) => ({\n  json: {\n    story_id: story.id,\n    article_id: article.id,\n    is_seed: index === 0,\n    similarity_score: 1.0 // All articles in cluster meet threshold\n  }\n}));\n\nreturn updates;"
      },
      "id": "prepare-links",
      "name": "Prepare Article Links",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
