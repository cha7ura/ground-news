    {
      "parameters": {
        "jsCode": "// Process unclustered articles and find clusters using Union-Find\nconst articles = $input.all().flatMap(item => \n  Array.isArray(item.json) ? item.json : [item.json]\n);\n\nif (articles.length === 0) {\n  return [{ json: { clusters: [], message: 'No articles to cluster' } }];\n}\n\n// Cosine similarity function\nfunction cosineSimilarity(a, b) {\n  if (!a || !b || a.length !== b.length) return 0;\n  let dotProduct = 0;\n  let normA = 0;\n  let normB = 0;\n  for (let i = 0; i < a.length; i++) {\n    dotProduct += a[i] * b[i];\n    normA += a[i] * a[i];\n    normB += b[i] * b[i];\n  }\n  if (normA === 0 || normB === 0) return 0;\n  return dotProduct / (Math.sqrt(normA) * Math.sqrt(normB));\n}\n\n// Union-Find for clustering\nclass UnionFind {\n  constructor(n) {\n    this.parent = Array.from({ length: n }, (_, i) => i);\n    this.rank = Array(n).fill(0);\n  }\n  find(x) {\n    if (this.parent[x] !== x) {\n      this.parent[x] = this.find(this.parent[x]);\n    }\n    return this.parent[x];\n  }\n  union(x, y) {\n    const px = this.find(x);\n    const py = this.find(y);\n    if (px === py) return;\n    if (this.rank[px] < this.rank[py]) {\n      this.parent[px] = py;\n    } else if (this.rank[px] > this.rank[py]) {\n      this.parent[py] = px;\n    } else {\n      this.parent[py] = px;\n      this.rank[px]++;\n    }\n  }\n}\n\nconst SIMILARITY_THRESHOLD = 0.85;\nconst uf = new UnionFind(articles.length);\n\n// Parse embeddings and compare pairs\nconst embeddings = articles.map(a => {\n  if (typeof a.embedding === 'string') {\n    try {\n      return JSON.parse(a.embedding);\n    } catch {\n      return null;\n    }\n  }\n  return a.embedding;\n});\n\n// Find similar pairs\nfor (let i = 0; i < articles.length; i++) {\n  for (let j = i + 1; j < articles.length; j++) {\n    if (embeddings[i] && embeddings[j]) {\n      const similarity = cosineSimilarity(embeddings[i], embeddings[j]);\n      if (similarity >= SIMILARITY_THRESHOLD) {\n        uf.union(i, j);\n      }\n    }\n  }\n}\n\n// Group articles by cluster\nconst clusterMap = new Map();\nfor (let i = 0; i < articles.length; i++) {\n  const root = uf.find(i);\n  if (!clusterMap.has(root)) {\n    clusterMap.set(root, []);\n  }\n  clusterMap.get(root).push({\n    id: articles[i].id,\n    source_id: articles[i].source_id,\n    title: articles[i].title,\n    url: articles[i].url,\n    published_at: articles[i].published_at\n  });\n}\n\n// Only keep clusters with 2+ articles (actual story clusters)\nconst clusters = Array.from(clusterMap.values())\n  .filter(cluster => cluster.length >= 2)\n  .map(cluster => ({\n    articles: cluster,\n    article_count: cluster.length,\n    source_count: new Set(cluster.map(a => a.source_id)).size,\n    // Use the earliest article's title as the story title\n    seed_article: cluster.sort((a, b) => \n      new Date(a.published_at) - new Date(b.published_at)\n    )[0]\n  }));\n\nreturn clusters.map(cluster => ({ json: cluster }));"
      },
