        "jsCode": "// Update articles with story_id\nconst cluster = $('Has Clusters?').item.json;\nconst story = $('Create Story').item.json;\n\nif (!story || !story.id) {\n  return [];\n}\n\nreturn cluster.articles.map(article => ({\n  json: {\n    id: article.id,\n    story_id: story.id\n  }\n}));"
      },
